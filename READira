.section-title {
    font-size: 28px;
    margin-bottom: 20px;
    color: #4CAF50;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.card {
    background: #16241d;
    padding: 20px;
    border-radius: 10px;
    transition: 0.3s;
}

.card:hover {
